# Copy to .env and fill in. The server refuses to start if anything here is
# missing or too weak - a misconfigured deploy should fail loudly at boot,
# not quietly sign tokens with `undefined`.

NODE_ENV=development
PORT=4000

# Postgres. The docker-compose.yml at the repo root matches these defaults.
DATABASE_URL="postgresql://tessera:tessera@localhost:5432/tessera?schema=public"

# Generate each of these separately:
#   openssl rand -base64 48
# They MUST differ. One shared secret would let a refresh token verify as an
# access token, turning a 30-day credential into a permanent one.
ACCESS_TOKEN_SECRET="replace-me-with-openssl-rand-base64-48-output-aaaaaa"
REFRESH_TOKEN_SECRET="replace-me-with-a-DIFFERENT-openssl-rand-value-bbbb"

# Seconds. Short access token, long refresh token - the refresh token is
# revocable, the access token is not, which is why one is brief.
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000

# Comma-separated. A wildcard is rejected outright in production.
CORS_ORIGINS=http://localhost:5173

# COOKIE_DOMAIN=.yourdomain.com
REPOSITORY_ROOT=./data/repositories
