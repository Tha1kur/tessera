{
  "name": "@tessera/core",
  "version": "0.1.0",
  "description": "The Tessera version control engine: content-addressed object store, trees, commits, refs and diffing.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "find src \\( -name '*.js' -o -name '*.d.ts' -o -name '*.map' \\) -delete; rm -rf dist *.tsbuildinfo",
    "pretest": "npm run clean"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
