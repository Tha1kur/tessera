# Always install devDependencies, even when NODE_ENV=production.
#
# Build platforms - Render, Heroku and others - set NODE_ENV=production before
# installing, and npm then omits devDependencies. That is normally sensible, but
# this project *builds* on that machine, and the compiler, its type definitions
# and the bundler all live in devDependencies. Without them the build fails with
# "Cannot find type definition file for 'node'".
#
# It is set here rather than as a flag on the build command because a platform
# may run a build command it recorded earlier, and silently ignore later edits.
# A config file in the repository cannot be missed that way.
#
# The runtime image is unaffected: the Dockerfile still prunes dev dependencies
# after compiling, so nothing extra ships to production.
include=dev
